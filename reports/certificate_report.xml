<odoo>
    <template id="certificate_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="certificate">
                <t t-call="web.basic_layout">

                    <div style="
                        width: 1100px;
                        height: 760px;
                        margin: 30px auto;
                        padding: 35px;
                        position: relative;
                        font-family: 'Times New Roman', serif;
                        color: #1f2d3d;
                        background: #ffffff;
                        border: 12px solid #1f4e79;
                        box-sizing: border-box;
                    ">

                        <!-- Inner Border -->
                        <div style="
                            position: absolute;
                            top: 18px;
                            left: 18px;
                            right: 18px;
                            bottom: 18px;
                            border: 3px solid #d4af37;
                        "></div>

                        <!-- Decorative Corner -->
                        <div style="position:absolute; top:35px; left:35px; width:70px; height:70px; border-top:5px solid #d4af37; border-left:5px solid #d4af37;"></div>
                        <div style="position:absolute; top:35px; right:35px; width:70px; height:70px; border-top:5px solid #d4af37; border-right:5px solid #d4af37;"></div>
                        <div style="position:absolute; bottom:35px; left:35px; width:70px; height:70px; border-bottom:5px solid #d4af37; border-left:5px solid #d4af37;"></div>
                        <div style="position:absolute; bottom:35px; right:35px; width:70px; height:70px; border-bottom:5px solid #d4af37; border-right:5px solid #d4af37;"></div>

                        <!-- Header -->
                        <div style="text-align:center; margin-top:35px; position:relative; z-index:2;">
                            <h3 style="margin:0; font-size:24px; color:#1f4e79; letter-spacing:2px;" t-esc="res_company.name or company.name"/>

                            <div style="width:220px; height:2px; background:#d4af37; margin:15px auto;"></div>

                            <h1 style="
                                margin: 25px 0 5px 0;
                                font-size: 48px;
                                color: #1f4e79;
                                letter-spacing: 3px;
                                text-transform: uppercase;
                            ">
                                CERTIFICATE
                            </h1>

                            <h2 style="
                                margin: 5px 0 20px 0;
                                font-size: 28px;
                                color: #d4af37;
                                font-style: italic;
                            " t-esc="certificate.name"/>
                        </div>

                        <!-- Body -->
                        <div style="
                            text-align:center;
                            padding: 0 80px;
                            margin-top: 35px;
                            position:relative;
                            z-index:2;
                        ">
                            <p style="font-size:22px; margin-bottom:20px;">
                                This is proudly presented to
                            </p>

                            <h2 style="
                                font-size:42px;
                                color:#1f4e79;
                                margin: 10px 0;
                                font-weight:bold;
                                border-bottom:2px solid #d4af37;
                                display:inline-block;
                                padding: 0 50px 8px 50px;
                            " t-esc="certificate.recipient_name"/>

                            <div style="
                                font-size:20px;
                                line-height:1.7;
                                margin:35px auto 0 auto;
                                width:80%;
                                color:#34495e;
                            " t-field="certificate.description"/>
                        </div>

                        <!-- Certificate Info -->
                        <div style="
                            position:absolute;
                            left:90px;
                            bottom:125px;
                            font-size:15px;
                            z-index:2;
                            color:#34495e;
                        ">
                            <p style="margin:4px 0;">
                                <strong>Certificate No:</strong>
                                <span t-esc="certificate.certificate_number"/>
                            </p>
                            <p style="margin:4px 0;">
                                <strong>Issue Date:</strong>
                                <span t-field="certificate.issue_date"/>
                            </p>
                            <p style="margin:4px 0;" t-if="certificate.expiry_date">
                                <strong>Valid Until:</strong>
                                <span t-field="certificate.expiry_date"/>
                            </p>
                            <p style="margin:4px 0;" t-if="certificate.certificate_type_id">
                                <strong>Certificate Type:</strong>
                                <span t-esc="certificate.certificate_type_id.name"/>
                            </p>
                        </div>

                        <!-- QR Code -->
                        <div style="
                            position:absolute;
                            left:92px;
                            bottom:45px;
                            text-align:center;
                            z-index:2;
                        ">
                            <t t-if="certificate.qr_code">
                                <img t-att-src="image_data_uri(certificate.qr_code)"
                                     style="height:75px; width:75px;"/>
                            </t>
                        </div>

                        <!-- Signature -->
                        <div style="
                            position:absolute;
                            right:100px;
                            bottom:75px;
                            width:260px;
                            text-align:center;
                            z-index:2;
                        ">
                            <t t-if="certificate.signatory_id and certificate.signatory_id.signature_image">
                                <img t-att-src="image_data_uri(certificate.signatory_id.signature_image)"
                                     style="height:75px; max-width:220px;"/>
                            </t>

                            <div style="border-top:2px solid #1f4e79; margin-top:10px; padding-top:6px;">
                                <strong style="font-size:17px;" t-esc="certificate.signatory_id.name if certificate.signatory_id else ''"/>
                                <br/>
                                <span style="font-size:14px; color:#555;">Principal / Director</span>
                            </div>
                        </div>

                        <!-- Seal -->
                        <div style="
                            position:absolute;
                            bottom:90px;
                            left:50%;
                            transform:translateX(-50%);
                            width:120px;
                            height:120px;
                            border:4px solid #d4af37;
                            border-radius:50%;
                            text-align:center;
                            line-height:120px;
                            color:#d4af37;
                            font-size:20px;
                            font-weight:bold;
                            opacity:0.35;
                            z-index:1;
                        ">
                            SEAL
                        </div>

                    </div>

                </t>
            </t>
        </t>
    </template>

    <record id="action_certificate_report" model="ir.actions.report">
        <field name="name">Certificate</field>
        <field name="model">certificate.issued</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">education_certificate_management.certificate_report_template</field>
        <field name="report_file">education_certificate_management.certificate_report_template</field>
        <field name="print_report_name">'CERT-' + (object.certificate_number or '')</field>
    </record>
</odoo>