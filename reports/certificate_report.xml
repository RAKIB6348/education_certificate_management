<odoo>
    <template id="certificate_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="certificate" t-value="o"/>
                <t t-call="web.basic_layout">

                    <div class="article"
     t-att-data-oe-model="certificate._name"
     t-att-data-oe-id="certificate.id"
     style="
        width: 1122px;
        height: 793px;
        margin: 0;
        padding: 28px;
        position: relative;
        font-family: 'Times New Roman', serif;
        color: #1f2d3d;
        background: #ffffff;
        border: 12px solid #1f4e79;
        box-sizing: border-box;
        overflow: hidden;
        page-break-after: avoid;
     ">

                        <!-- Inner Border -->
                        <div style="
                            position: absolute;
                            top: 18px;
                            left: 18px;
                            right: 18px;
                            bottom: 18px;
                            border: 3px solid #d4af37;
                        "></div>

                        <!-- Decorative Corner -->
                        <div style="position:absolute; top:35px; left:35px; width:70px; height:70px; border-top:5px solid #d4af37; border-left:5px solid #d4af37;"></div>
                        <div style="position:absolute; top:35px; right:35px; width:70px; height:70px; border-top:5px solid #d4af37; border-right:5px solid #d4af37;"></div>
                        <div style="position:absolute; bottom:35px; left:35px; width:70px; height:70px; border-bottom:5px solid #d4af37; border-left:5px solid #d4af37;"></div>
                        <div style="position:absolute; bottom:35px; right:35px; width:70px; height:70px; border-bottom:5px solid #d4af37; border-right:5px solid #d4af37;"></div>

                        <!-- Header -->
                        <div style="text-align:center; margin-top:20px; position:relative; z-index:2;">
                            <div style="width:75px; height:75px; line-height:75px; margin:0 auto 12px auto; background:#1f4e79; border:3px solid #d4af37; border-radius:50%; text-align:center; overflow:hidden;">
                                <t t-if="res_company.logo">
                                    <img t-att-src="image_data_uri(res_company.logo)"
                                         style="width:64px; height:64px; max-width:64px; max-height:64px; margin-top:5px; object-fit:contain;"/>
                                </t>
                                <t t-else="">
                                    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg"
                                         style="width:42px; height:42px; margin-top:16px;">
                                        <path fill="#d4af37" d="M32 10 4 24l28 14 28-14L32 10z"/>
                                        <path fill="#d4af37" d="M18 32v10c0 5 7 9 14 9s14-4 14-9V32l-14 7-14-7z"/>
                                        <path fill="#d4af37" d="M52 27v14h-4V29l4-2z"/>
                                    </svg>
                                </t>
                            </div>
                            <h3 style="margin:0; font-size:24px; color:#1f4e79; letter-spacing:2px;"
                                t-esc="res_company.name or company.name"/>

                            <div style="width:220px; height:2px; background:#d4af37; margin:15px auto;"></div>

                            <h1 style="
                                margin: 25px 0 5px 0;
                                font-size: 48px;
                                color: #1f4e79;
                                letter-spacing: 3px;
                                text-transform: uppercase;
                            ">
                                CERTIFICATE
                            </h1>

                            <h2 style="
                                margin: 5px 0 20px 0;
                                font-size: 28px;
                                color: #d4af37;
                                font-style: italic;
                            " t-esc="certificate.name"/>
                        </div>

                        <!-- Body -->
                        <div style="
    text-align:center;
    padding: 0 80px;
    margin-top: 28px;
    position:relative;
    z-index:2;
">
                            <p style="
        font-size:22px;
        margin-bottom:18px;
        color:#1f2d3d;
    ">
                                This is proudly presented to
                            </p>

                            <h2 style="
        font-size:42px;
        color:#1f4e79;
        margin: 10px 0;
        font-weight:bold;
        border-bottom:2px solid #d4af37;
        display:inline-block;
        padding: 0 50px 8px 50px;
    " t-esc="certificate.recipient_name"/>

                            <div style="
        font-size:16px;
        line-height:1.75;
        margin:30px auto 60px auto;
        width:72%;
        max-height:95px;
        overflow:hidden;
        color:#1f2d3d;
        text-align:center;
        font-family:'Times New Roman', serif;
    " t-field="certificate.description"/>
                        </div>

                        <!-- Bottom Info + QR + Signature Section -->
                        <div style="
                            position:absolute;
                            left:65px;
                            right:65px;
                            bottom:52px;
                            height:125px;
                            z-index:2;
                            font-family: Arial, sans-serif;
                        ">

                            <!-- Certificate Info - Left -->
                            <div style="
                                position:absolute;
                                left:0;
                                bottom:12px;
                                width:320px;
                                font-size:15px;
                                color:#1f2d3d;
                                line-height:1.45;
                            ">
                                <p style="margin:2px 0;">
                                    <strong style="color:#1f4e79;">Certificate No:</strong>
                                    <span t-esc="certificate.certificate_number"/>
                                </p>

                                <p style="margin:2px 0;">
                                    <strong style="color:#1f4e79;">Issue Date:</strong>
                                    <span t-field="certificate.issue_date"/>
                                </p>

                                <p style="margin:2px 0;" t-if="certificate.expiry_date">
                                    <strong style="color:#1f4e79;">Valid Until:</strong>
                                    <span t-field="certificate.expiry_date"/>
                                </p>
                            </div>

                            <!-- QR Code - Center Left -->
                            <div style="
        position:absolute;
        left:390px;
        bottom:0;
        width:95px;
        text-align:center;
    ">
                                <t t-if="certificate.qr_code">
                                    <img t-att-src="image_data_uri(certificate.qr_code)"
                                         style="
                    height:78px;
                    width:78px;
                    border:1px solid #1f4e79;
                    padding:5px;
                    background:#ffffff;
                 "/>
                                </t>

                                <div style="
            margin-top:5px;
            font-size:10px;
            color:#1f4e79;
            letter-spacing:1.2px;
            text-transform:uppercase;
        ">
                                    Scan to Verify
                                </div>
                            </div>

                            <!-- Signature - Right -->
                            <div style="
        position:absolute;
        right:95px;
        bottom:0;
        width:280px;
        text-align:center;
        color:#1f4e79;
    ">
                                <t t-if="certificate.signatory_id and certificate.signatory_id.signature_image">
                                    <img t-att-src="image_data_uri(certificate.signatory_id.signature_image)"
                                         style="
                    height:55px;
                    max-width:210px;
                    object-fit:contain;
                    margin-bottom:3px;
                 "/>
                                </t>

                                <div style="
            border-top:2px solid #1f4e79;
            margin:7px auto 0 auto;
            padding-top:6px;
            width:245px;
        ">
                                    <strong style="
                font-size:17px;
                color:#1f4e79;
                font-family:'Times New Roman', serif;
            " t-esc="certificate.signatory_id.name if certificate.signatory_id else ''"/>

                                    <br/>

                                    <span style="
                font-size:14px;
                color:#555555;
                font-style:italic;
                font-family:'Times New Roman', serif;
            ">
                                        Principal / Director
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Seal -->
                        <div style="
                            position:absolute;
                            bottom:90px;
                            left:50%;
                            transform:translateX(-50%);
                            width:120px;
                            height:120px;
                            border:4px solid #d4af37;
                            border-radius:50%;
                            text-align:center;
                            line-height:120px;
                            color:#d4af37;
                            font-size:20px;
                            font-weight:bold;
                            opacity:0.35;
                            z-index:1;
                        ">
                            SEAL
                        </div>

                    </div>

                </t>
            </t>
        </t>
    </template>

    <record id="paperformat_certificate_landscape" model="report.paperformat">
        <field name="name">Certificate Landscape Full Page</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="dpi">96</field>
        <field name="disable_shrinking" eval="True"/>
    </record>


    <record id="action_certificate_report" model="ir.actions.report">
        <field name="name">Certificate</field>
        <field name="model">certificate.issued</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">education_certificate_management.certificate_report_template</field>
        <field name="report_file">education_certificate_management.certificate_report_template</field>
        <field name="paperformat_id" ref="education_certificate_management.paperformat_certificate_landscape"/>
        <field name="print_report_name">'CERT-' + (object.recipient_name or '')</field>
    </record>
</odoo>