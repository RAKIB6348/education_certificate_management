<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="certificate_template_tree" model="ir.ui.view">
        <field name="name">certificate.template.tree</field>
        <field name="model">certificate.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="certificate_type_id"/>
                <field name="signatory_title"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="certificate_template_form" model="ir.ui.view">
        <field name="name">certificate.template.form</field>
        <field name="model">certificate.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="is_active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="certificate_type_id"/>
                        <field name="signatory_title"/>
                        <field name="background_image" widget="image" height="300" width="450"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_certificate_template" model="ir.actions.act_window">
        <field name="name">Certificate Templates</field>
        <field name="res_model">certificate.template</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_certificate_template"
              name="Certificate Templates"
              parent="school_certificate.menu_certificate_root"
              action="action_certificate_template"
              sequence="10"/>
</odoo>