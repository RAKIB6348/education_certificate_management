<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="certificate_type_tree" model="ir.ui.view">
        <field name="name">certificate.type.tree</field>
        <field name="model">certificate.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="certificate_type_form" model="ir.ui.view">
        <field name="name">certificate.type.form</field>
        <field name="model">certificate.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_certificate_type" model="ir.actions.act_window">
        <field name="name">Certificate Types</field>
        <field name="res_model">certificate.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_certificate_type"
              name="Certificate Types"
              parent="menu_certificate_root"
              action="action_certificate_type"
              sequence="5"/>
</odoo>